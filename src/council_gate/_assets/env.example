# council-gate — environment configuration
# Copy to .env and fill in. .env is gitignored.

# OpenRouter is the default routing layer (one key, many models).
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# Comma-separated list of OpenRouter model IDs to seat on the council.
# Diversity matters more than count: cross provider AND cross capability tier.
# See README §"Council composition" for rationale.
# Default mix is deliberately broad: 6 providers so excluding any single
# generator-provider still leaves >=4 diverse seats. Qwen and DeepSeek are
# included specifically because they decorrelate from the US frontier cluster
# (different pretraining mix, different post-training norms).
COUNCIL_MODELS=anthropic/claude-opus-4.7,openai/gpt-5,google/gemini-2.5-pro,meta-llama/llama-3.3-70b-instruct,qwen/qwen-2.5-72b-instruct,deepseek/deepseek-chat

# Optional: direct provider keys if you'd rather not route through OpenRouter.
# Adapters check OPENROUTER_API_KEY first; fall back to these per-provider keys.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional: codex CLI adapter assumes `codex` is on PATH and authenticated
# separately (see https://github.com/openai/codex). No key needed here.

# Entropy gate threshold (0.0 = identical outputs, 1.0 = maximally divergent).
# Above this, gate fires escalation. Tune empirically per artifact type.
GATE_THRESHOLD=0.35

# Where escalation messages are written (file path or 'stdout').
# council-gate never auto-sends — it formats the message; you copy-paste.
ESCALATION_OUTPUT=stdout
