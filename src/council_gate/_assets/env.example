# council-gate — environment configuration
# Lives at ~/.config/council-gate/.env (XDG-compliant). Edit any time.

# OpenRouter is the default routing layer (one key, many models).
# Sign up: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Comma-separated list of OpenRouter model IDs to seat on the council.
#
# DEFAULT is cost-conscious across six model families (OpenAI, Google,
# Anthropic, Zhipu, DeepSeek, Moonshot) so excluding any single one (the
# generator) still leaves >=4 seats with diverse blindspots.
#
# This default works on a low OpenRouter balance ($1-2 covers many runs).
# For higher-stakes reviews, swap in the flagship variants (see "alternatives"
# at the bottom of this file).
COUNCIL_MODELS=openai/gpt-5.6-luna,google/gemini-3.5-flash,anthropic/claude-sonnet-5,z-ai/glm-5.2,deepseek/deepseek-v4-pro,moonshotai/kimi-k3

# Optional: codex CLI adapter (assumes `codex` is on PATH and authenticated).
# Set to 0 to disable the codex seat entirely.
COUNCIL_INCLUDE_CODEX=1

# Disagreement threshold τ ∈ [0, 1] above which the gate fires escalation.
# Default 0.35; tune empirically per artifact type.
GATE_THRESHOLD=0.35

# Ask providers to enforce the review-form JSON schema server-side
# (OpenRouter structured outputs). Seats that don't support it fall back
# to plain prompting automatically. Set to 0 to disable everywhere.
COUNCIL_STRUCTURED_OUTPUT=1

# ──────────────────────────────────────────────────────────────────────────
# Alternatives — uncomment to swap in
# ──────────────────────────────────────────────────────────────────────────
#
# Flagship mix (higher cost, higher quality; needs a topped-up balance):
# COUNCIL_MODELS=openai/gpt-5.6-terra,google/gemini-3.1-pro-preview,anthropic/claude-opus-4.8,z-ai/glm-5.2,deepseek/deepseek-v4-pro,moonshotai/kimi-k3
#
# Minimum-viable cheap mix (3 seats, very low cost):
# COUNCIL_MODELS=z-ai/glm-5.2,deepseek/deepseek-v4-pro,google/gemini-3.5-flash
